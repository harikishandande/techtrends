## Docker commands used to build the application
# Run from inside the techtrends/ directory (where the Dockerfile lives).
# -t tags the image as "techtrends"; the "." is the build context and the
# location of the Dockerfile (./Dockerfile).
cd techtrends
docker build -t techtrends .


## Docker commands used to run the application
# Run in detached mode (-d) and expose container port 3111 on host port 7111.
docker run -d -p 7111:3111 techtrends

# The application is now accessible at http://127.0.0.1:7111


## Docker commands used to get the application logs
# Find the running container ID:
docker ps
# Retrieve the logs (replace <CONTAINER_ID> with the value from `docker ps`):
docker logs <CONTAINER_ID>


